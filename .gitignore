# Wails / frontend build output
build/bin

# Go build temp dir (GOTMPDIR) — kept inside the project because the
# antivirus exclusion covers the project folder but not %TEMP%
.gotmp/
node_modules
frontend/dist/*
!frontend/dist/gitkeep

# Compiled Go binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
/gobchat-log-browser

# Go test/coverage artifacts
*.test
*.out
coverage.*

# Chat logs are personal/sensitive — never commit real logs.
# Synthetic test fixtures under testdata/ are committed explicitly (exception below).
*.log
!**/testdata/**

# Local convenience scripts
build.bat
build+run.bat

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
*.local
