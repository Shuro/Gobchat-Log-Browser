# Wails / frontend build output
build/bin

# Velopack packaging output (vpk pack --outputDir)
release_out/

# Local analysis/report output (codemap diffs, etc.)
.reports/

# Go build temp dir (GOTMPDIR) — kept inside the project because the
# antivirus exclusion covers the project folder but not %TEMP%
.gotmp/
node_modules
frontend/dist/*
!frontend/dist/gitkeep

# Compiled Go binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
/gobchat-log-browser

# Go test/coverage artifacts
*.test
*.out
coverage.*

# Chat logs are personal/sensitive — never commit real logs.
# Synthetic test fixtures under testdata/ and the AI-generated example logs
# under docs/examples/mock-logs/ are committed explicitly (exceptions below).
*.log
!**/testdata/**
!docs/examples/mock-logs/*.log

# Local convenience scripts
build.bat
build+run.bat

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
*.local

# Claude Code project config (personal settings + vendored ECC rules)
.claude/settings.local.json
.claude/rules/ecc/
